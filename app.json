{
  "expo": {
    "name": "opstap",
    "slug": "opstap",
    "scheme": "opstap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pascalwiersma.opstap",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "OpStap gebruikt je locatie om je op de kaart te tonen.",
        "NSPhotoLibraryUsageDescription": "OpStap gebruikt je fotobibliotheek om je profielfoto in te stellen.",
        "NFCReaderUsageDescription": "OpStap gebruikt NFC om je identiteitsdocument te scannen voor verificatie."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.pascalwiersma.opstap"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-secure-store",
      "@rnmapbox/maps",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "OpStap gebruikt je locatie om je op de kaart te tonen."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "OpStap gebruikt je fotobibliotheek om je profielfoto in te stellen."
        }
      ],
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ],
      "@didit-protocol/sdk-react-native"
    ]
  }
}
